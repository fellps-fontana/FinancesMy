// Financeiro Pessoal — schema v1
// Importar em https://dbdiagram.io
// Reflete as decisoes da regra-de-negocio.md

Table conta {
  id uuid [pk]
  nome varchar [not null]
  origem varchar [not null, note: 'OPEN_FINANCE | MANUAL']
  tipo varchar [note: 'BANCO | CARTAO | INVESTIMENTO']
  pierre_account_id varchar [note: 'null se manual']
  saldo_manual decimal [note: 'null se Open Finance, CARTAO, ou INVESTIMENTO com ativos (nesses casos saldo e calculado)']
  dia_fechamento int [note: 'so CARTAO; dia de fechamento da fatura']
  dia_vencimento int [note: 'so CARTAO; dia de vencimento da fatura']
  ativa boolean [not null, default: true]
}

Table categoria {
  id uuid [pk]
  nome varchar [not null]
  tipo varchar [not null, note: 'DESPESA | RECEITA']
  parent_id uuid [ref: > categoria.id, note: 'null se categoria raiz']
  arquivada boolean [not null, default: false]
}

Table de_para_categoria {
  id uuid [pk]
  categoria_pierre varchar [not null, note: 'string vinda da API do Pierre ou descricao importada']
  categoria_id uuid [ref: > categoria.id, note: 'minha categoria']
}

Table lancamento {
  id uuid [pk]
  pierre_txn_id varchar [note: 'null se manual; chave de dedup do sync']
  conta_id uuid [ref: > conta.id, not null]
  categoria_id uuid [ref: > categoria.id, note: 'null = sem categoria']
  descricao varchar
  valor decimal [not null]
  tipo varchar [not null, note: 'DEBIT | CREDIT — fonte da verdade do sinal']
  data date [not null]
  status varchar [not null, note: 'PENDENTE | SUGERIDO | PAGO']
  manual boolean [not null, default: false]
  oculto boolean [not null, default: false, note: 'soft-delete de lancamento OF']
  conta_fixa_id uuid [ref: > conta_fixa.id, note: 'null se avulso']
  conciliado_com uuid [ref: - lancamento.id, note: 'txn OF vinculada na conciliacao']
  transferencia_id uuid [ref: > transferencia.id, note: 'null se nao for perna de transferencia (item 3/12)']
  fatura_id uuid [ref: > fatura.id, note: 'null se nao for compra de cartao (item 12)']
}

// Transferencia de mesma titularidade (item 3). Modelo de duas pernas:
// dois lancamentos (saida na origem, entrada no destino) compartilham o mesmo
// transferencia_id. Nao conta como gasto nem receita. Pagamento de fatura de
// cartao e uma transferencia conta corrente -> conta CARTAO (item 12).
// fatura_id: 1:N (nao 1:1) porque o pagamento de fatura pode ser PARCIAL
// (varias transferencias quitando a mesma fatura aos poucos) e ANTECIPADO
// (transferencia antes do ciclo fechar). Por isso a FK fica na transferencia
// e nao na fatura.
Table transferencia {
  id uuid [pk]
  data date [not null]
  valor decimal [not null]
  conta_origem_id uuid [ref: > conta.id, not null]
  conta_destino_id uuid [ref: > conta.id, not null]
  fatura_id uuid [ref: > fatura.id, note: 'null se nao for pagamento de fatura de cartao (item 12)']
  descricao varchar
}

// Ciclo de fatura do cartao (item 12). Agrupa as compras (lancamento.fatura_id)
// e os pagamentos (transferencia.fatura_id, 1:N — pagamento parcial/antecipado
// gera varias transferencias para a mesma fatura). Saldo do cartao e
// calculado, nao armazenado: compras - pagamentos - estornos. Saldo pendente
// da fatura = soma das compras da fatura - soma das transferencias
// (pagamentos) vinculadas a ela.
Table fatura {
  id uuid [pk]
  conta_id uuid [ref: > conta.id, not null, note: 'conta do tipo CARTAO']
  data_fechamento date [not null]
  data_vencimento date [not null]
  status varchar [not null, note: 'ABERTA | FECHADA | PAGA — PAGA so quando o saldo pendente chega a zero']
}

Table conta_fixa {
  id uuid [pk]
  conta_id uuid [ref: > conta.id, not null]
  categoria_id uuid [ref: > categoria.id]
  descricao varchar [not null]
  valor decimal [not null]
  dia_vencimento int [not null, note: '1-31']
  ativa boolean [not null, default: true]
}

Table parcela {
  id uuid [pk]
  lancamento_id uuid [ref: > lancamento.id, not null]
  numero int [not null, note: 'parcela atual, ex: 3']
  total int [not null, note: 'total de parcelas, ex: 10']
  valor decimal [not null]
  vencimento date [not null]
  paga boolean [not null, default: false]
}

// Ativo (item 8). Existe dentro de uma conta tipo INVESTIMENTO. Quando uma
// conta tem ao menos um ativo, o saldo da conta deixa de vir de saldo_manual
// e passa a ser calculado (item 10): soma(quantidade x preco_atual) dos
// ativos com ativa=true.
Table ativo {
  id uuid [pk]
  conta_id uuid [ref: > conta.id, not null, note: 'conta deve ser tipo INVESTIMENTO; validado no Service, nao via FK/CHECK']
  ticker varchar [not null]
  nome varchar [note: 'nome de exibicao do ativo, opcional']
  quantidade decimal [not null, note: 'posicao atual (pos-venda); atualizada em toda compra/venda']
  preco_medio decimal [not null, note: 'custo medio ponderado sobre a posicao atual; recalcula so em COMPRA (item 8); venda NUNCA altera']
  preco_atual decimal [not null, note: 'informado manualmente pelo usuario a cada compra; usado no calculo de patrimonio e no grafico de diferenca (item 8)']
  ativa boolean [not null, default: true, note: 'false quando quantidade chega a zero por venda total (item 8); soft-delete, mesmo padrao de conta.ativa/categoria.arquivada/lancamento.oculto']
  criado_em timestamp [not null, default: `now()`]
}

// Historico de compra/venda por ativo (item 8). Necessario para recalcular
// preco_medio corretamente apos venda parcial, e serve de extrato auditavel.
Table movimentacao_ativo {
  id uuid [pk]
  ativo_id uuid [ref: > ativo.id, not null]
  tipo varchar [not null, note: 'COMPRA | VENDA']
  quantidade decimal [not null]
  preco_unitario decimal [not null, note: 'preco de compra ou de venda informado naquela operacao']
  data date [not null]
  observacao varchar
}

Table limite_gasto {
  id uuid [pk]
  categoria_id uuid [ref: > categoria.id, not null]
  valor_limite decimal [not null]
  periodo varchar [not null, default: 'MENSAL']
}
